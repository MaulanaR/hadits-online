<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hasil Pencarian: "{{.Query}}" - Sunnah.com</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Amiri+Quran&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/static/style.css">
    <style>
        .arabic-text {
            font-family: 'Amiri Quran', serif;
            line-height: 2.5;
            font-size: 1.25rem;
        }
        .indonesian-text {
            font-family: 'Inter', sans-serif;
            line-height: 1.8;
        }
        .highlight {
            background-color: #fef3c7;
            padding: 2px 4px;
            border-radius: 2px;
        }
        .filter-checkbox:checked + label {
            background-color: #10b981;
            color: white;
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Header -->
    <header class="bg-emerald-700 text-white shadow-lg">
        <div class="container mx-auto px-4 py-6">
            <div class="flex flex-col md:flex-row justify-between items-center">
                <div class="flex items-center">
                    <a href="/" class="text-2xl md:text-3xl font-bold mb-4 md:mb-0 hover:text-emerald-200 transition">Sunnah.com</a>
                    <span class="mx-3">/</span>
                    <span class="text-xl">Pencarian</span>
                </div>
                <nav class="flex flex-col md:flex-row space-y-2 md:space-y-0 md:space-x-6">
                    <a href="/" class="hover:text-emerald-200 transition">Beranda</a>
                    <a href="/favorites" class="hover:text-emerald-200 transition">Favorit</a>
                    <a href="#collections" class="hover:text-emerald-200 transition">Koleksi</a>
                    <div class="relative">
                        <input type="text" id="searchInput" value="{{.Query}}" placeholder="Cari hadith..." 
                               class="px-4 py-2 rounded-lg text-gray-800 bg-white w-full md:w-64">
                        <button onclick="performSearch()" class="absolute right-2 top-2 text-emerald-600">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            </svg>
                        </button>
                    </div>
                </nav>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="container mx-auto px-4 py-8">
        <!-- Search Filters -->
        <section class="mb-8">
            <div class="bg-white rounded-lg shadow-md p-6">
                <h3 class="text-xl font-bold text-gray-800 mb-4">Filter Pencarian</h3>
                
                <form id="filterForm" class="space-y-6">
                    <!-- Current Query -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Kata Kunci:</label>
                        <input type="text" name="q" value="{{.Query}}" 
                               class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-emerald-500 focus:border-emerald-500"
                               placeholder="Masukkan kata kunci pencarian...">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <!-- Language Filter -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Bahasa:</label>
                            <select name="lang" 
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-emerald-500 focus:border-emerald-500">
                                <option value="all" {{if eq .Filters.Language "all"}}selected{{end}}>Semua</option>
                                <option value="ar" {{if eq .Filters.Language "ar"}}selected{{end}}>Arab</option>
                                <option value="id" {{if eq .Filters.Language "id"}}selected{{end}}>Indonesia</option>
                            </select>
                        </div>

                        <!-- Sort By -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Urutkan:</label>
                            <select name="sort" 
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-emerald-500 focus:border-emerald-500">
                                <option value="relevance" {{if eq .Filters.SortBy "relevance"}}selected{{end}}>Relevansi</option>
                                <option value="number" {{if eq .Filters.SortBy "number"}}selected{{end}}>Nomor Hadith</option>
                                <option value="collection" {{if eq .Filters.SortBy "collection"}}selected{{end}}>Koleksi</option>
                            </select>
                        </div>

                        <!-- Hadith Number Range -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Nomor Hadith:</label>
                            <div class="flex space-x-2">
                                <input type="number" name="min" value="{{if .Filters.NumberRange.Min}}{{.Filters.NumberRange.Min}}{{end}}" 
                                       placeholder="Min" min="1"
                                       class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:ring-emerald-500 focus:border-emerald-500">
                                <input type="number" name="max" value="{{if .Filters.NumberRange.Max}}{{.Filters.NumberRange.Max}}{{end}}" 
                                       placeholder="Max" min="1"
                                       class="flex-1 px-3 py-2 border border-gray-300 rounded-md focus:ring-emerald-500 focus:border-emerald-500">
                            </div>
                        </div>
                    </div>

                    <!-- Collections Filter -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Koleksi:</label>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                            {{range .Collections}}
                            <div class="flex items-center">
                                <input type="checkbox" id="col-{{.Slug}}" name="collections" value="{{.Slug}}" 
                                       {{if hasFilter $.Filters.Collections .Slug}}checked{{end}}
                                       class="filter-checkbox h-4 w-4 text-emerald-600 focus:ring-emerald-500 border-gray-300 rounded">
                                <label for="col-{{.Slug}}" 
                                       class="ml-2 text-sm text-gray-700 cursor-pointer hover:text-emerald-600">
                                    {{.Name}} ({{.Total}})
                                </label>
                            </div>
                            {{end}}
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex space-x-3">
                        <button type="submit" 
                                class="px-6 py-2 bg-emerald-600 text-white rounded-md hover:bg-emerald-700 transition">
                            🔍 Terapkan Filter
                        </button>
                        <button type="button" onclick="clearFilters()" 
                                class="px-6 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 transition">
                            🔄 Reset Filter
                        </button>
                    </div>
                </form>
            </div>
        </section>

        <!-- Search Results Header -->
        <section class="mb-6">
            <div class="flex justify-between items-center bg-white rounded-lg shadow-md p-4">
                <div>
                    <h1 class="text-2xl font-bold text-gray-800">Hasil Pencarian</h1>
                    <p class="text-gray-600">
                        Menampilkan hasil untuk: <span class="font-semibold">"{{.Query}}"</span>
                        {{if .Results}}
                        <span class="ml-2 text-emerald-600 font-medium">
                            ({{.Pagination.TotalItems}} hasil)
                        </span>
                        {{else}}
                        <span class="ml-2 text-red-600">(Tidak ada hasil)</span>
                        {{end}}
                    </p>
                </div>
                {{if gt .Pagination.TotalPages 1}}
                <div class="text-sm text-gray-600">
                    Halaman {{.Pagination.CurrentPage}} dari {{.Pagination.TotalPages}}
                </div>
                {{end}}
            </div>
        </section>

        {{if .Results}}
        <!-- Search Results -->
        <section class="space-y-8 mb-8" id="search-results">
            {{range .Results}}
            <div class="bg-white rounded-lg shadow-md">
                <div class="p-6 border-b border-gray-200">
                    <div class="flex items-center justify-between">
                        <h3 class="text-xl font-semibold text-gray-800">{{.Info.Name}}</h3>
                        <a href="/collection/{{.Slug}}" class="text-emerald-600 hover:text-emerald-800 font-medium">
                            Lihat Koleksi →
                        </a>
                    </div>
                    <p class="text-gray-600 mt-1">{{len .Hadiths}} hadith ditemukan</p>
                </div>
                
                <div class="divide-y divide-gray-200">
                    {{range .Hadiths}}
                    <div class="p-6 hover:bg-gray-50 transition">
                        <div class="flex items-start justify-between mb-3">
                            <h4 class="text-lg font-medium text-gray-700">Hadith {{.Hadith.Number}}</h4>
                            <div class="flex items-center space-x-2">
                                {{if gt .Score 100}}
                                <span class="px-2 py-1 bg-emerald-100 text-emerald-800 text-xs rounded-full">Sangat Relevan</span>
                                {{else if gt .Score 50}}
                                <span class="px-2 py-1 bg-blue-100 text-blue-800 text-xs rounded-full">Relevan</span>
                                {{end}}
                                <a href="/collection/{{$.Slug}}/{{.Hadith.Number}}" 
                                   class="text-emerald-600 hover:text-emerald-800 text-sm font-medium">
                                    Baca Selengkapnya →
                                </a>
                            </div>
                        </div>
                        
                        <div class="space-y-3">
                            <div class="arabic-text text-right text-gray-800 leading-loose max-h-32 overflow-hidden">
                                {{.Hadith.Arab}}
                            </div>
                            <div class="indonesian-text text-gray-700 text-sm searchable-content">
                                {{.Context}}
                            </div>
                        </div>
                    </div>
                    {{end}}
                </div>
            </div>
            {{end}}
        </section>

        <!-- Pagination -->
        {{if gt .Pagination.TotalPages 1}}
        <section class="mb-8">
            <div class="bg-white rounded-lg shadow-md p-4">
                <div class="flex justify-center">
                    <div class="flex space-x-2">
                        {{if .Pagination.HasPrev}}
                            <a href="{{buildFilterURL $.Query $.Filters 1}}" 
                               class="px-3 py-1 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 transition">
                                ← Sebelumnya
                            </a>
                        {{end}}
                        
                        {{range $i := pageNumbers .Pagination.CurrentPage .Pagination.TotalPages}}
                            {{if eq $i $.Pagination.CurrentPage}}
                                <span class="px-3 py-1 bg-emerald-600 text-white rounded">{{$i}}</span>
                            {{else}}
                                <a href="{{buildFilterURL $.Query $.Filters $i}}" 
                                   class="px-3 py-1 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 transition">
                                    {{$i}}
                                </a>
                            {{end}}
                        {{end}}
                        
                        {{if .Pagination.HasNext}}
                            <a href="{{buildFilterURL $.Query $.Filters (add .Pagination.CurrentPage 1)}}" 
                               class="px-3 py-1 bg-gray-200 text-gray-700 rounded hover:bg-gray-300 transition">
                                Selanjutnya →
                            </a>
                        {{end}}
                    </div>
                </div>
            </div>
        </section>
        {{end}}

        {{if not .Results}}
        <!-- No Results -->
        <section class="text-center py-12">
            <div class="bg-white rounded-lg shadow-md p-8">
                <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <h3 class="text-xl font-semibold text-gray-800 mb-2">Tidak Ada Hasil</h3>
                <p class="text-gray-600 mb-6">
                    Tidak ditemukan hadits yang cocok dengan pencarian "<span class="font-semibold">{{.Query}}</span>" dan filter yang dipilih.
                </p>
                <div class="space-y-4 text-left max-w-md mx-auto">
                    <p class="text-gray-600 font-medium">Saran:</p>
                    <ul class="space-y-2 text-gray-600">
                        <li>• Gunakan kata kunci yang berbeda</li>
                        <li>• Periksa ejaan kata</li>
                        <li>• Kurangi filter yang terlalu spesifik</li>
                        <li>• Coba dengan kata yang lebih umum</li>
                        <li>• Coba dalam bahasa Arab atau Indonesia</li>
                        <li>• Periksa nomor hadith yang dimaksud</li>
                    </ul>
                </div>
                <div class="flex flex-col sm:flex-row gap-4 justify-center mt-6">
                    <button onclick="clearFilters()" 
                            class="px-6 py-3 bg-gray-300 text-gray-700 rounded-lg hover:bg-gray-400 transition">
                        🔄 Reset Filter
                    </button>
                    <a href="/" class="px-6 py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition">
                        🏠 Kembali ke Beranda
                    </a>
                </div>
            </div>
        </section>
        {{end}}
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-8">
        <div class="container mx-auto px-4 text-center">
            <p class="mb-2">Sunnah.com - Kumpulan Hadits Nabi Muhammad SAW</p>
            <p class="text-gray-400">© 2026 - Dibuat dengan cinta untuk pembelajaran Islam</p>
        </div>
    </footer>

    <script src="/static/script.js"></script>
    <script>
        {{- $query := urlEncode .Query -}}
        function clearFilters() {
            window.location.href = '/search?q={{$query}}';
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            {{if .Query}}
            highlightSearchResults('{{$query}}');
            {{end}}
        });
    </script>
</body>
</html>
